{
  "expo": {
    "name": "Consientemente",
    "slug": "consientemente",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "consientemente",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#4A90D9"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
